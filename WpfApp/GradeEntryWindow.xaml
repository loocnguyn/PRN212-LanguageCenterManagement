<Window x:Class="WpfApp.GradeEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Grade Entry" Height="620" Width="860"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Class ID:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="txtClassId" Width="120" Height="28" VerticalContentAlignment="Center" Padding="4,0"/>
            <Button Content="Load"  Width="80" Height="28" Margin="6,0,0,0" Click="BtnLoad_Click"/>
            <Button Content="Reset" Width="80" Height="28" Margin="6,0,0,0" Click="BtnReset_Click"/>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="dgGrades"
                  AutoGenerateColumns="False" IsReadOnly="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Student ID"   Binding="{Binding StudentId}"   Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Student Name" Binding="{Binding StudentName}"  Width="180" IsReadOnly="True"/>
                <DataGridTextColumn Header="Grade Type"   Binding="{Binding GradeType}"    Width="130" IsReadOnly="True"/>
                <DataGridTextColumn Header="Score"        Binding="{Binding Score}"        Width="80"/>
                <DataGridTextColumn Header="Note"         Binding="{Binding Note}"         Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Save Grades" Width="130" Height="32" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
