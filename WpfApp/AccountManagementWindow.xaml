<Window x:Class="WpfApp.AccountManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account Management" Height="620" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="txtSearch" Width="200" Height="30" VerticalContentAlignment="Center" Padding="4,0"/>
            <Button Content="Search" Width="70" Height="30" Margin="6,0,0,0" Click="BtnSearch_Click"/>
            <TextBlock Text="Role:" VerticalAlignment="Center" Margin="16,0,6,0"/>
            <ComboBox x:Name="cmbFilterRole" Width="120" Height="30" SelectionChanged="CmbFilterRole_Changed" HorizontalContentAlignment="Left" Padding="4,2" VerticalContentAlignment="Center">
                <ComboBoxItem Content="All" IsSelected="True"/>
                <ComboBoxItem Content="ADMIN"/>
                <ComboBoxItem Content="STAFF"/>
                <ComboBoxItem Content="TEACHER"/>
                <ComboBoxItem Content="STUDENT"/>
            </ComboBox>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="dgUsers"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"         Binding="{Binding Id}"                                          Width="50"/>
                <DataGridTextColumn Header="Username"   Binding="{Binding Username}"                                    Width="150"/>
                <DataGridTextColumn Header="Role"       Binding="{Binding Role}"                                        Width="100"/>
                <DataGridTextColumn Header="Created At" Binding="{Binding CreatedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button Content="«" Width="32" Height="32" Margin="0,0,4,0" Click="BtnFirst_Click"/>
                <Button Content="‹" Width="32" Height="32" Margin="0,0,4,0" Click="BtnPrev_Click"/>
                <TextBlock x:Name="txtPage" VerticalAlignment="Center" Margin="4,0"/>
                <Button Content="›" Width="32" Height="32" Margin="4,0,4,0" Click="BtnNext_Click"/>
                <Button Content="»" Width="32" Height="32" Click="BtnLast_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Add"        Width="90"  Height="32" Margin="0,0,8,0" Click="BtnAdd_Click"/>
                <Button Content="Edit"       Width="90"  Height="32" Margin="0,0,8,0" Click="BtnEdit_Click"/>
                <Button Content="Deactivate" Width="100" Height="32" Click="BtnDelete_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
