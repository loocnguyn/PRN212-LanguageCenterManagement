<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp"
        mc:Ignorable="d"
        Title="Language Center Management"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Hệ thống">
                <MenuItem Header="Quản lý tài khoản" Click="MenuAccountManagement_Click"/>
                <Separator/>
                <MenuItem Header="Đăng xuất" Click="MenuLogout_Click"/>
            </MenuItem>
            <MenuItem Header="Học viên" Click="MenuStudents_Click"/>
            <MenuItem Header="Giáo viên" Click="MenuTeachers_Click"/>
            <MenuItem Header="Khóa học" Click="MenuCourses_Click"/>
            <MenuItem Header="Lớp học" Click="MenuClasses_Click"/>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="Sẵn sàng"/>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <TextBlock x:Name="txtWelcome"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="18" Foreground="Gray"/>
        </Grid>
    </DockPanel>
</Window>
