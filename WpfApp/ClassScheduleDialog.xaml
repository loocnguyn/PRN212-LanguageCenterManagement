<Window x:Class="WpfApp.ClassScheduleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Class Schedule" Height="320" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/><ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Class:" VerticalAlignment="Center" Margin="0,6"/>
        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cboClass" Height="28" Margin="0,4" DisplayMemberPath="Name" SelectedValuePath="ClassId"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Day of Week:" VerticalAlignment="Center" Margin="0,6"/>
        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cboDayOfWeek" Height="28" Margin="0,4" DisplayMemberPath="Key" SelectedValuePath="Value"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Start Time:" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtStartTime" Height="28" VerticalContentAlignment="Center" Margin="0,4"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="End Time:" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtEndTime" Height="28" VerticalContentAlignment="Center" Margin="0,4"/>

        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save"   Width="80" Height="30" Margin="0,0,8,0" Click="BtnSave_Click"/>
            <Button Content="Cancel" Width="80" Height="30" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
