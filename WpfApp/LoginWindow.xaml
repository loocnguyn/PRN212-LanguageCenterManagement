<Window x:Class="WpfApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Language Center — Login"
        Height="360" Width="420" MinHeight="360" MinWidth="380"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Language Center Management"
                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="2" Text="Username"
                   FontSize="13" Margin="0,0,0,4"/>
        <TextBox Grid.Row="3" x:Name="txtUsername"
                 Height="34" FontSize="14"
                 VerticalContentAlignment="Center" Padding="6,0"/>

        <TextBlock Grid.Row="5" Text="Password"
                   FontSize="13" Margin="0,0,0,4"/>
        <PasswordBox Grid.Row="6" x:Name="pwdPassword"
                     Height="34" FontSize="14"
                     VerticalContentAlignment="Center" Padding="6,0"/>

        <Button Grid.Row="8" Content="Login"
                Height="38" FontSize="14"
                Click="BtnLogin_Click"/>
    </Grid>
</Window>
