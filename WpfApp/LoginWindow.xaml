<Window x:Class="WpfApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Language Center — Đăng nhập"
        Height="280" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Language Center Management"
                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>

        <TextBox Grid.Row="2" x:Name="txtUsername"
                 Height="32" FontSize="14"
                 VerticalContentAlignment="Center"
                 Text=""/>

        <PasswordBox Grid.Row="4" x:Name="pwdPassword"
                     Height="32" FontSize="14"
                     VerticalContentAlignment="Center"/>

        <Button Grid.Row="6" Content="Đăng nhập"
                Height="36" FontSize="14"
                Click="BtnLogin_Click"/>
    </Grid>
</Window>
