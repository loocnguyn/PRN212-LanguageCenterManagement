<Window x:Class="WpfApp.ClassScheduleManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Class Schedule Management" Height="620" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Class:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="cboClassFilter" Width="200" Height="30" DisplayMemberPath="Name" SelectedValuePath="ClassId"
                      SelectionChanged="CboClassFilter_SelectionChanged"/>
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="12,0,6,0"/>
            <TextBox x:Name="txtSearch" Width="200" Height="30" VerticalContentAlignment="Center" Padding="4,0"/>
            <Button Content="Search" Width="80" Height="30" Margin="6,0,0,0" Click="BtnSearch_Click"/>
            <Button Content="Reset"  Width="80" Height="30" Margin="6,0,0,0" Click="BtnReset_Click"/>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="dgSchedules"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="DgSchedules_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ScheduleId}" Width="50"/>
                <DataGridTextColumn Header="Class" Binding="{Binding ClassName}" Width="140"/>
                <DataGridTextColumn Header="Day" Binding="{Binding DayName}" Width="100"/>
                <DataGridTextColumn Header="Start" Binding="{Binding StartTimeStr}" Width="100"/>
                <DataGridTextColumn Header="End" Binding="{Binding EndTimeStr}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Add"    Width="90" Height="32" Margin="0,0,8,0" Click="BtnAdd_Click"/>
            <Button Content="Edit"   Width="90" Height="32" Margin="0,0,8,0" Click="BtnEdit_Click"/>
            <Button Content="Delete" Width="90" Height="32" Click="BtnDelete_Click"/>
        </StackPanel>
    </Grid>
</Window>
