<Window x:Class="WpfApp.TeacherManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Teacher Management" Height="620" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="txtSearch" Width="250" Height="30" VerticalContentAlignment="Center" Padding="4,0"/>
            <Button Content="Search" Width="80" Height="30" Margin="6,0,0,0" Click="BtnSearch_Click"/>
            <Button Content="Reset"  Width="80" Height="30" Margin="6,0,0,0" Click="BtnReset_Click"/>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="dgTeachers"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="DgTeachers_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding TeacherId}" Width="60"/>
                <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="180"/>
                <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" Width="80"/>
                <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Specialization" Binding="{Binding Specialization}" Width="150"/>
                <DataGridTextColumn Header="Degree" Binding="{Binding Degree}" Width="100"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Add"    Width="90" Height="32" Margin="0,0,8,0" Click="BtnAdd_Click"/>
            <Button Content="Edit"   Width="90" Height="32" Margin="0,0,8,0" Click="BtnEdit_Click"/>
            <Button Content="Delete" Width="90" Height="32" Click="BtnDelete_Click"/>
        </StackPanel>
    </Grid>
</Window>

