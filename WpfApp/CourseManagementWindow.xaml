<Window x:Class="WpfApp.CourseManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Course Management" Height="620" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="txtSearch" Width="250" Height="30" VerticalContentAlignment="Center" Padding="4,0"/>
            <Button Content="Search" Width="80" Height="30" Margin="6,0,0,0" Click="BtnSearch_Click"/>
            <Button Content="Reset"  Width="80" Height="30" Margin="6,0,0,0" Click="BtnReset_Click"/>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="dgCourses"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="DgCourses_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding CourseId}" Width="50"/>
                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="90"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="70"/>
                <DataGridTextColumn Header="Language" Binding="{Binding Language}" Width="100"/>
                <DataGridTextColumn Header="Sessions" Binding="{Binding DurationSessions}" Width="80"/>
                <DataGridTextColumn Header="Fee" Binding="{Binding TuitionFee}" Width="100"/>
                <DataGridTextColumn Header="Active" Binding="{Binding IsActive}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Add"    Width="90" Height="32" Margin="0,0,8,0" Click="BtnAdd_Click"/>
            <Button Content="Edit"   Width="90" Height="32" Margin="0,0,8,0" Click="BtnEdit_Click"/>
            <Button Content="Delete" Width="90" Height="32" Click="BtnDelete_Click"/>
        </StackPanel>
    </Grid>
</Window>

