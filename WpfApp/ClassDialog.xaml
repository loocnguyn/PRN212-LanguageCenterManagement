<Window x:Class="WpfApp.ClassDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Class" Height="480" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/><ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtName" Height="28" VerticalContentAlignment="Center" Margin="0,4"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Course:" VerticalAlignment="Center" Margin="0,6"/>
        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cboCourse" Height="28" Margin="0,4" DisplayMemberPath="Name" SelectedValuePath="CourseId"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Teacher:" VerticalAlignment="Center" Margin="0,6"/>
        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cboTeacher" Height="28" Margin="0,4" DisplayMemberPath="FullName" SelectedValuePath="TeacherId"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Classroom:" VerticalAlignment="Center" Margin="0,6"/>
        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cboClassroom" Height="28" Margin="0,4" DisplayMemberPath="Name" SelectedValuePath="ClassroomId"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Max Students:" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtMaxStudents" Height="28" VerticalContentAlignment="Center" Margin="0,4"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Start Date:" VerticalAlignment="Center" Margin="0,6"/>
        <DatePicker Grid.Row="5" Grid.Column="1" x:Name="dpStartDate" Height="28" Margin="0,4"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="End Date:" VerticalAlignment="Center" Margin="0,6"/>
        <DatePicker Grid.Row="6" Grid.Column="1" x:Name="dpEndDate" Height="28" Margin="0,4"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Status:" VerticalAlignment="Center" Margin="0,6"/>
        <ComboBox Grid.Row="7" Grid.Column="1" x:Name="cboStatus" Height="28" Margin="0,4"/>

        <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save"   Width="80" Height="30" Margin="0,0,8,0" Click="BtnSave_Click"/>
            <Button Content="Cancel" Width="80" Height="30" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
