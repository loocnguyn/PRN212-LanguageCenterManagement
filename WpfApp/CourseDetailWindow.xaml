<Window x:Class="WpfApp.CourseDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Course" Height="500" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Code -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Code" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtCode" Height="30" VerticalContentAlignment="Center" Padding="4,0" Margin="0,0,0,10"/>

        <!-- Name -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Name" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtName" Height="30" VerticalContentAlignment="Center" Padding="4,0" Margin="0,0,0,10"/>

        <!-- Level -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Level" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cmbLevel" Height="30" Margin="0,0,0,10"
                  HorizontalContentAlignment="Left" Padding="4,3" VerticalContentAlignment="Center">
            <ComboBoxItem Content="Beginner"/>
            <ComboBoxItem Content="Elementary"/>
            <ComboBoxItem Content="Intermediate"/>
            <ComboBoxItem Content="Advanced"/>
            <ComboBoxItem Content="Proficiency"/>
        </ComboBox>

        <!-- Language -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Language" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cmbLanguage" Height="30" Margin="0,0,0,10"
                  HorizontalContentAlignment="Left" Padding="4,3" VerticalContentAlignment="Center">
            <ComboBoxItem Content="English"/>
            <ComboBoxItem Content="Japanese"/>
            <ComboBoxItem Content="Korean"/>
            <ComboBoxItem Content="Chinese"/>
            <ComboBoxItem Content="French"/>
            <ComboBoxItem Content="German"/>
        </ComboBox>

        <!-- Duration Sessions -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Duration Sessions" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtDuration" Height="30" VerticalContentAlignment="Center" Padding="4,0" Margin="0,0,0,10"/>

        <!-- Tuition Fee -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Tuition Fee" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <TextBox Grid.Row="5" Grid.Column="1" x:Name="txtFee" Height="30" VerticalContentAlignment="Center" Padding="4,0" Margin="0,0,0,10"/>

        <!-- Description -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Description" VerticalAlignment="Top" Margin="0,6,0,10"/>
        <TextBox Grid.Row="6" Grid.Column="1" x:Name="txtDescription" Height="70"
                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 VerticalContentAlignment="Top" Padding="4,4" Margin="0,0,0,10"/>

        <!-- IsActive -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Active" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <CheckBox Grid.Row="7" Grid.Column="1" x:Name="chkActive" VerticalAlignment="Center" Margin="0,0,0,10" IsChecked="True"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Width="90" Height="32" Margin="0,0,8,0" Click="BtnSave_Click"/>
            <Button Content="Cancel" Width="90" Height="32" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
