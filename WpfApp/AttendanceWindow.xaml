<Window x:Class="WpfApp.AttendanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Attendance" Height="620" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Session ID:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="txtSessionId" Width="120" Height="28" VerticalContentAlignment="Center" Padding="4,0"/>
            <Button Content="Load"  Width="80" Height="28" Margin="6,0,0,0" Click="BtnLoad_Click"/>
            <Button Content="Reset" Width="80" Height="28" Margin="6,0,0,0" Click="BtnReset_Click"/>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="dgAttendance"
                  AutoGenerateColumns="False" IsReadOnly="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Student ID"   Binding="{Binding StudentId}"    Width="100"/>
                <DataGridTextColumn Header="Student Name" Binding="{Binding StudentName}"  Width="180"/>
                <DataGridComboBoxColumn Header="Status"   SelectedItemBinding="{Binding Status}" Width="120">
                    <DataGridComboBoxColumn.ItemsSource>
                        <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                            <sys:String>PRESENT</sys:String>
                            <sys:String>ABSENT</sys:String>
                            <sys:String>LATE</sys:String>
                        </x:Array>
                    </DataGridComboBoxColumn.ItemsSource>
                </DataGridComboBoxColumn>
                <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Save Attendance" Width="140" Height="32" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
