<Window x:Class="WpfApp.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Payment" Height="520" Width="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Invoice selector -->
        <GroupBox Grid.Row="0" Header="Select Invoice" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Invoice ID:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="txtInvoiceId" Width="120" Height="28" VerticalContentAlignment="Center" Padding="4,0"/>
                <Button Content="Load" Width="80" Height="28" Margin="8,0,0,0" Click="BtnLoadInvoice_Click"/>
            </StackPanel>
        </GroupBox>
        <!-- Invoice summary -->
        <GroupBox Grid.Row="1" Header="Invoice Summary" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Amount:"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="lblTotal"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Already Paid:"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="lblPaid"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Remaining:"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="lblRemaining" Foreground="Red"/>
            </Grid>
        </GroupBox>
        <!-- Payment form -->
        <GroupBox Grid.Row="2" Header="Record Payment" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Amount:" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtAmount" Height="28" VerticalContentAlignment="Center" Padding="4,0" Margin="0,4"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Method:" VerticalAlignment="Center"/>
                <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="cmbMethod" Height="28" Margin="0,4">
                    <ComboBoxItem Content="CASH" IsSelected="True"/>
                    <ComboBoxItem Content="BANK_TRANSFER"/>
                    <ComboBoxItem Content="CARD"/>
                </ComboBox>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Note:" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="txtNote" Height="28" VerticalContentAlignment="Center" Padding="4,0" Margin="0,4"/>
            </Grid>
        </GroupBox>
        <Button Grid.Row="3" Content="Record Payment" Width="150" Height="34"
                HorizontalAlignment="Right" Margin="0,10,0,0" Click="BtnPay_Click"/>
    </Grid>
</Window>
