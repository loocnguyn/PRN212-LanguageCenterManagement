<Window x:Class="WpfApp.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Payment" Height="680" Width="980"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="txtSearch" Width="220" Height="28"
                     VerticalContentAlignment="Center" Padding="4,0"/>
            <Button Content="Search" Width="80" Height="28" Margin="8,0,0,0"
                    Click="BtnSearch_Click"/>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="dgInvoices" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single"
                  SelectionChanged="DgInvoices_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Invoice ID" Binding="{Binding InvoiceId}" Width="80"/>
                <DataGridTextColumn Header="Student ID" Binding="{Binding StudentId}" Width="80"/>
                <DataGridTextColumn Header="Student" Binding="{Binding StudentName}" Width="160"/>
                <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="110"/>
                <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount}" Width="110"/>
                <DataGridTextColumn Header="Remaining" Binding="{Binding RemainingAmount}" Width="110"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Due Date" Binding="{Binding DueDate}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,8,0,0">
            <Button x:Name="btnPrevious" Content="Previous" Width="90" Height="30"
                    Margin="0,0,8,0" Click="BtnPrevious_Click"/>
            <TextBlock x:Name="txtPageInfo" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button x:Name="btnNext" Content="Next" Width="90" Height="30"
                    Click="BtnNext_Click"/>
        </StackPanel>

        <GroupBox Grid.Row="3" Header="Payment Details" Padding="10" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/><ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="110"/><ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="80"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="38"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Invoice ID:"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtInvoiceId"
                         Margin="0,5,12,5" IsReadOnly="True"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Remaining:"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="3" x:Name="txtRemaining"
                         Margin="0,5,12,5" IsReadOnly="True"/>
                <TextBlock Grid.Row="0" Grid.Column="4" Text="Staff:"
                           VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="5" x:Name="cmbStaff" Margin="0,5"
                          DisplayMemberPath="DisplayText" SelectedValuePath="StaffId"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Amount paid:"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtAmountPaid"
                         Margin="0,5,12,5"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Method:"
                           VerticalAlignment="Center"/>
                <ComboBox Grid.Row="1" Grid.Column="3" x:Name="cmbMethod"
                          Margin="0,5,12,5">
                    <ComboBoxItem Content="Cash" IsSelected="True"/>
                    <ComboBoxItem Content="Transfer"/>
                    <ComboBoxItem Content="Card"/>
                </ComboBox>
                <TextBlock Grid.Row="1" Grid.Column="4" Text="Note:"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="5" x:Name="txtNote" Margin="0,5"/>
            </Grid>
        </GroupBox>

        <Button Grid.Row="4" Content="Record Payment" Width="150" Height="34"
                HorizontalAlignment="Right" Margin="0,10,0,0"
                Click="BtnPay_Click"/>
    </Grid>
</Window>
