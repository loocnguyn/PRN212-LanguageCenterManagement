<Window x:Class="WpfApp.ClassResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Class Results" Height="580" Width="860"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Class ID:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="txtClassId" Width="120" Height="28" VerticalContentAlignment="Center" Padding="4,0"/>
            <Button Content="Load"  Width="80" Height="28" Margin="6,0,0,0" Click="BtnLoad_Click"/>
            <Button Content="Reset" Width="80" Height="28" Margin="6,0,0,0" Click="BtnReset_Click"/>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="dgResults"
                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Student ID"   Binding="{Binding StudentId}"   Width="100"/>
                <DataGridTextColumn Header="Full Name"    Binding="{Binding StudentName}"  Width="180"/>
                <DataGridTextColumn Header="Grade Type"   Binding="{Binding GradeType}"    Width="130"/>
                <DataGridTextColumn Header="Score"        Binding="{Binding Score}"        Width="80"/>
                <DataGridTextColumn Header="Graded At"    Binding="{Binding GradedAt}"     Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
