<Window x:Class="WpfApp.StudentInvoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="My Invoices" Height="520" Width="760"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Student ID:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="txtStudentId" Width="120" Height="28" VerticalContentAlignment="Center" Padding="4,0"/>
            <Button Content="Load"  Width="80" Height="28" Margin="6,0,0,0" Click="BtnLoad_Click"/>
            <Button Content="Reset" Width="80" Height="28" Margin="6,0,0,0" Click="BtnReset_Click"/>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="dgInvoices"
                  AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Invoice ID" Binding="{Binding InvoiceId}"  Width="90"/>
                <DataGridTextColumn Header="Amount"     Binding="{Binding Amount}"      Width="110"/>
                <DataGridTextColumn Header="Paid"       Binding="{Binding PaidAmount}"  Width="110"/>
                <DataGridTextColumn Header="Due Date"   Binding="{Binding DueDate}"     Width="110"/>
                <DataGridTextColumn Header="Status"     Binding="{Binding Status}"      Width="100"/>
                <DataGridTextColumn Header="Note"       Binding="{Binding Note}"        Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
