<Window x:Class="WpfApp.TeacherScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="My Schedule" Height="540" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Teacher ID:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="txtTeacherId" Width="120" Height="28" VerticalContentAlignment="Center" Padding="4,0"/>
            <Button Content="Load"  Width="80" Height="28" Margin="6,0,0,0" Click="BtnLoad_Click"/>
            <Button Content="Reset" Width="80" Height="28" Margin="6,0,0,0" Click="BtnReset_Click"/>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="dgSchedule"
                  AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Class"    Binding="{Binding ClassName}"   Width="140"/>
                <DataGridTextColumn Header="Day"      Binding="{Binding DayOfWeek}"   Width="90"/>
                <DataGridTextColumn Header="Start"    Binding="{Binding StartTime}"   Width="90"/>
                <DataGridTextColumn Header="End"      Binding="{Binding EndTime}"     Width="90"/>
                <DataGridTextColumn Header="Room"     Binding="{Binding RoomName}"    Width="110"/>
                <DataGridTextColumn Header="Course"   Binding="{Binding CourseName}"  Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
