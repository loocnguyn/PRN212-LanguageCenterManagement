<Window x:Class="WpfApp.AccountDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account Detail" Height="340" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Username" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtUsername" Height="30" VerticalContentAlignment="Center" Padding="4,0" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Password" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="pwdPassword" Height="30" Padding="4,0" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="(để trống = giữ nguyên)" Grid.ColumnSpan="2"
                   FontSize="11" Foreground="Gray" Margin="0,0,0,10"
                   x:Name="lblPasswordHint" Visibility="Collapsed"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Role" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <ComboBox  Grid.Row="3" Grid.Column="1" x:Name="cmbRole" Height="30" Margin="0,0,0,10">
            <ComboBoxItem Content="ADMIN"/>
            <ComboBoxItem Content="STAFF"/>
            <ComboBoxItem Content="TEACHER"/>
            <ComboBoxItem Content="STUDENT"/>
        </ComboBox>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Active" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <CheckBox  Grid.Row="4" Grid.Column="1" x:Name="chkActive" VerticalAlignment="Center" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save"   Width="90" Height="32" Margin="0,0,8,0" Click="BtnSave_Click"/>
            <Button Content="Cancel" Width="90" Height="32" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
