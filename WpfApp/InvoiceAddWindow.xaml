<Window x:Class="WpfApp.InvoiceAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Invoice" Height="390" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Student ID:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtStudentId" Margin="0,6"/>
        <TextBlock Grid.Row="1" Text="Enrollment ID:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtEnrollmentId" Margin="0,6"/>
        <TextBlock Grid.Row="2" Text="Amount:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtAmount" Margin="0,6"/>
        <TextBlock Grid.Row="3" Text="Due date:" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="3" Grid.Column="1" x:Name="dpDueDate" Margin="0,6"/>
        <TextBlock Grid.Row="4" Text="Note:" VerticalAlignment="Top" Margin="0,9,0,0"/>
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtNote"
                 Margin="0,6" AcceptsReturn="True" TextWrapping="Wrap"/>
        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Save" Width="90" Height="32" Margin="0,0,8,0"
                    Click="BtnSave_Click"/>
            <Button Content="Cancel" Width="90" Height="32" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
