<Window x:Class="WpfApp.CourseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Course" Height="360" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/><ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Code:" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtCode" Height="28" VerticalContentAlignment="Center" Margin="0,4"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtName" Height="28" VerticalContentAlignment="Center" Margin="0,4"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Level:" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtLevel" Height="28" VerticalContentAlignment="Center" Margin="0,4"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Language:" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtLanguage" Height="28" VerticalContentAlignment="Center" Margin="0,4"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Description:" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtDescription" Height="28" VerticalContentAlignment="Center" Margin="0,4"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Sessions:" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox Grid.Row="5" Grid.Column="1" x:Name="txtSessions" Height="28" VerticalContentAlignment="Center" Margin="0,4"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Fee:" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox Grid.Row="6" Grid.Column="1" x:Name="txtFee" Height="28" VerticalContentAlignment="Center" Margin="0,4"/>

        <CheckBox Grid.Row="7" Grid.Column="1" x:Name="chkIsActive" Content="Active" VerticalAlignment="Center" Margin="0,8" IsChecked="True"/>

        <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save"   Width="80" Height="30" Margin="0,0,8,0" Click="BtnSave_Click"/>
            <Button Content="Cancel" Width="80" Height="30" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
