<Window x:Class="WpfApp.AttendanceHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Attendance History" Height="560" Width="820"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Student ID:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="txtStudentId" Width="120" Height="28" VerticalContentAlignment="Center" Padding="4,0"/>
            <Button Content="Load"  Width="80" Height="28" Margin="6,0,0,0" Click="BtnLoad_Click"/>
            <Button Content="Reset" Width="80" Height="28" Margin="6,0,0,0" Click="BtnReset_Click"/>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="dgHistory"
                  AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Session ID" Binding="{Binding SessionId}"    Width="90"/>
                <DataGridTextColumn Header="Class"      Binding="{Binding ClassName}"    Width="150"/>
                <DataGridTextColumn Header="Date"       Binding="{Binding SessionDate}"  Width="110"/>
                <DataGridTextColumn Header="Status"     Binding="{Binding Status}"       Width="100"/>
                <DataGridTextColumn Header="Note"       Binding="{Binding Note}"         Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
